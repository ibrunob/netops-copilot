# NetOps Copilot local development configuration
#
# This file contains only non-secret defaults and is safe to copy to the
# untracked .env file. It is development-only; do not reuse these values in a
# shared environment. Secrets are intentionally listed only as comments below.

# API process configuration (used by services/api)
NETOPS_ENVIRONMENT=local
NETOPS_SERVICE_NAME=netops-api
NETOPS_API_VERSION=0.1.0
NETOPS_HOST=0.0.0.0
NETOPS_PORT=8000
WEB_PORT=3000
NETOPS_RELOAD=false
NETOPS_DOCS_ENABLED=true
NETOPS_LOG_LEVEL=INFO
# Endpoint/DSN are optional and supplied only by approved deployments.
NETOPS_OTEL_TRACES_ENABLED=true
# NETOPS_OTEL_EXPORTER_OTLP_ENDPOINT=
# NETOPS_SENTRY_DSN=
NETOPS_SENTRY_TRACES_SAMPLE_RATE=0.0
NETOPS_RATE_LIMIT_ENABLED=true
NETOPS_RATE_LIMIT_REQUESTS=120
NETOPS_RATE_LIMIT_WINDOW_SECONDS=60

# Server-to-server API location for the Next.js BFF/API boundary
NETOPS_API_BASE_URL=http://localhost:8000

# Browser-visible OpenID Connect issuer for the web BFF. Docker Compose gives
# the container private discovery/token endpoints separately; do not replace
# this public issuer with the Compose service DNS name.
NETOPS_OIDC_ISSUER=http://localhost:8080/realms/netops-dev
NETOPS_OIDC_CLIENT_ID=netops-web
NETOPS_OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
# Browser hostname used by Compose for its OIDC callback. Keep localhost for a
# normal local browser. The 0.0.0.0 in-app-browser mode must also set
# NETOPS_COOKIE_SECURE=false in the ignored local .env file.
NETOPS_OIDC_PUBLIC_HOST=localhost
# Defaults to true. Set false only for the local HTTP in-app browser.
NETOPS_COOKIE_SECURE=true

# API dependency locations. These defaults use Docker Compose service DNS.
NETOPS_DEPENDENCIES__POSTGRES__HOST=postgres
NETOPS_DEPENDENCIES__POSTGRES__PORT=5432
NETOPS_DEPENDENCIES__REDIS__HOST=redis
NETOPS_DEPENDENCIES__REDIS__PORT=6379
NETOPS_DEPENDENCIES__MINIO__HOST=minio
NETOPS_DEPENDENCIES__MINIO__PORT=9000
NETOPS_DEPENDENCIES__TEMPORAL__HOST=temporal
NETOPS_DEPENDENCIES__TEMPORAL__PORT=7233
NETOPS_DEPENDENCIES__KEYCLOAK__HOST=keycloak
NETOPS_DEPENDENCIES__KEYCLOAK__PORT=8080

# Artifact-storage policy. The local API uses MinIO only through short-lived,
# signed browser upload capabilities; it verifies completed objects privately.
# Compose supplies the endpoint and credentials from the local MinIO settings.
NETOPS_ARTIFACT_STORE__ENABLED=true
NETOPS_ARTIFACT_STORE__BUCKET=netops-artifacts
NETOPS_ARTIFACT_STORE__PRESIGN_TTL_SECONDS=300
NETOPS_ARTIFACT_STORE__PUBLIC_ENDPOINT_URL=http://localhost:9000

# Worker malware scanning. ClamAV is private to the local Compose network;
# keep this enabled for local artifact intake and do not publish its port.
NETOPS_CLAMAV_ENABLED=true
NETOPS_CLAMAV_MAX_SCAN_BYTES=104857600

# Docker Compose local platform: non-secret names and host port mappings.
POSTGRES_DB=netops
POSTGRES_USER=netops
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=netops-artifacts
TEMPORAL_GRPC_PORT=7233
TEMPORAL_UI_PORT=8233
KEYCLOAK_PORT=8080
REDPANDA_KAFKA_PORT=19092
REDPANDA_ADMIN_PORT=9644
REDPANDA_SCHEMA_REGISTRY_PORT=8081

# Local-only sensitive values: `make env` generates the password values in the
# untracked .env file. Never put real, staging, or production credentials here.
# These identity labels are public development-only names, not secrets.
MINIO_ROOT_USER=netops-local
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=netops-admin
# The following passwords are appended by `make env` only to the untracked .env.
# POSTGRES_PASSWORD=
# POSTGRES_APP_PASSWORD=
# MINIO_ROOT_PASSWORD=
# KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=
# NETOPS_SESSION_ENCRYPTION_SECRET=
